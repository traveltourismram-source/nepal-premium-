# ─── Nepal Route Planner – Backend Environment ───────────────────────
# Copy this file to .env and fill in real values before running.

# Server
PORT=4000
NODE_ENV=development

# JWT
# Generate a strong secret: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=change_this_to_a_long_random_secret_at_least_64_chars
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# Database (SQLite file path, relative to backend/ dir)
DB_PATH=./data/nepal_route.db

# CORS – comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:5173,http://localhost:4173

# Anthropic (optional – for server-side AI tip proxying so key stays private)
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Rate limiting (requests per window)
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=200
